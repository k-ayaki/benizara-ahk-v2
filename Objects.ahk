#Requires AutoHotkey v2.0
;----------------------------------------------------------------------
;	オブジェクトの要素数を数える
;----------------------------------------------------------------------
CountObject(_obj)
{
	_cnt := 0
	; v2では _NewEnum() の代わりに for ループを直接使用します
	for k, v in _obj
	{
		_cnt += 1
	}
	return _cnt
}

;----------------------------------------------------------------------
; オブジェクトの要素を削除
;----------------------------------------------------------------------
RemoveObject(_obj)
{
	if (IsObject(_obj)) {
		; v2では、Map や Array の全削除には Clear() メソッドを使用するのが最も安全で高速です
		if (HasMethod(_obj, "Clear")) {
			_obj.Clear()
		} else {
			; 古い形式のオブジェクト（プロパティ）として使われている場合のフォールバック
			for k, v in _obj.OwnProps() {
				_obj.DeleteProp(k)
			}
		}
	}
}

;----------------------------------------------------------------------
; オブジェクトの要素リストを返す
;----------------------------------------------------------------------
listSimulMode(_Romaji)
{
	global g_SimulMode

	_ddlist := ""
	; こちらも for ループで簡潔に記述できます
	for k, v in g_SimulMode
	{
		if (SubStr(v, 1, 1) == _Romaji) {
			_ddlist .= v . "|"
		}
	}
	return _ddlist
}